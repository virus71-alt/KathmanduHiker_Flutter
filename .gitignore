# Flutter / Dart
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
flutter_*.png
linked_*.ds
unlinked.ds
unlinked_spec.ds
coverage/

# IDE
.idea/
*.iml
.vscode/

# ─────────────────────────────────────────────────────────────────────
# Secrets & credentials — NEVER commit these.
# Per ULTIMATE.md §2.1 and §12.1, leaking any of these is an instant
# rejection and requires rotation + git-history rewrite to remediate.
# ─────────────────────────────────────────────────────────────────────

# Firebase config (per-platform — fetch from the Firebase Console)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
ios/Runner/GoogleService-Info2.plist
lib/firebase_options.dart

# Android signing & local SDK config
*.keystore
*.jks
android/key.properties
android/local.properties
android/.gradle/
android/app/upload-keystore.jks
android/app/debug.keystore

# iOS signing & per-machine config
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
ios/.symlinks/
ios/Pods/
*.mobileprovision
*.p8
*.p12
*.cer
*.certSigningRequest

# Environment files
.env
.env.local
.env.development
.env.staging
.env.production

# Build artifacts (don't ship binaries through git)
*.apk
*.aab
*.ipa
*.app
*.dSYM.zip

# Generated by flutter create — only ignore platforms we don't ship.
# android/ and ios/ ARE version-controlled because they contain critical
# config (manifest, ATS, signing wiring, network security) per
# ULTIMATE.md §12.1. Secrets within them are excluded above.
linux/
macos/
windows/
web/

# Build artifacts inside the platform folders (would otherwise leak gigabytes).
android/build/
android/app/build/
android/captures/
android/.idea/
android/.kotlin/
ios/build/
ios/DerivedData/
ios/.idea/

# Claude Code session state — not project files.
.claude/

# OS
.DS_Store
Thumbs.db
