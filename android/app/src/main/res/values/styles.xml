<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Dark launch theme — shows Yama splash while Flutter engine initialises. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>
    <!-- Transparent bridge theme — keeps dark bg while Flutter draws its first frame. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/yama_splash_bg</item>
    </style>
</resources>
